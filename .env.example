# Radar de Vendas v004

# Obrigatória para análise e transcrição.
OPENAI_API_KEY=

# Opcionais. Altere somente se o modelo estiver disponível na sua conta OpenAI.
OPENAI_MODEL=gpt-4o
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe

# Opcional: fixa a origem autorizada para chamadas das APIs.
# Exemplo: https://radardevendas.vercel.app
RADAR_ALLOWED_ORIGIN=
